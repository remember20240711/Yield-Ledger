[Unit]
Description=息流账本 / Dividend Ledger Web Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/yield-ledger-local/backend
EnvironmentFile=/opt/yield-ledger-local/.env
ExecStart=/opt/yield-ledger-local/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --loop asyncio
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
